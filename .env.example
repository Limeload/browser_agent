# Copy this file to .env and fill in your keys.
# .env is git-ignored and must never be committed.

# Required for intent parsing (Claude claude-sonnet-4-6)
ANTHROPIC_API_KEY=

# Required for audio transcription (Whisper-1)
OPENAI_API_KEY=

# Optional — Browserbase remote browser (Week 2)
# Leave blank to use local Chromium instead
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Optional — PostgreSQL for injection event logging (Week 4)
# Default (matches docker-compose.yml): postgresql://guardagent:guardagent@localhost:5432/guardagent
# Leave blank to disable persistence (agent runs without a DB)
DATABASE_URL=

# Optional — default: info
LOG_LEVEL=info
